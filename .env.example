# VAJRA environment template — copy to .env and fill in. .env is gitignored; NEVER commit real values.
# Network params verified 2026-07-19 against https://docs.monad.xyz/developer-essentials/network-information

# Deployment only (Foundry). Real key lives in local .env ONLY.
DEPLOYER_PRIVATE_KEY=0xREPLACE_WITH_LOCAL_KEY_NEVER_COMMIT

# Monad Mainnet
VAJRA_RPC_URL=https://rpc.monad.xyz
NEXT_PUBLIC_VAJRA_CHAIN_ID=143
NEXT_PUBLIC_VAJRA_CONTRACT_ADDRESS=          # filled after deploy, written once, consumed everywhere
NEXT_PUBLIC_VAJRA_EXPLORER_URL=https://monadscan.com    # MonadVision: https://monadvision.com (alternative)
NEXT_PUBLIC_VAJRA_RP_ID=                     # production passkey RP ID, set after domain control confirmed
NEXT_PUBLIC_VAJRA_ORIGIN=                    # e.g. https://vajra.xyz — must match RP ID
